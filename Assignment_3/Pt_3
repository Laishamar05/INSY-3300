import math

user_accepted_loan = False

while not user_accepted_loan:

    valid_principal = False

    while not valid_principal:
        principal = float(input("Enter the amount of loan requested (1K-20K): $")) # validate this
        
        if 1000 <= principal <=  20000: # Use this if to check if principal is between 1000 and 20000
            valid_principal = True
        else:
            print("Please enter valid ammount between 1000 and 20000.")
        

    # Validate number of months using another while
    valid_months = False
    while not valid_months:
        months = int(input("Enter the loan term in months (3 to 36): "))
        if 3 <= months <= 36:
            valid_months = True
        else: 
            print("Please enter valid term between 3 and 36 months.")
            
    # Implement remaining code
    if 3 <= months <= 12:
        annual_rate = 0.02
    elif 13 <= months <= 24:
        annual_rate = 0.03
    else:
        annual_rate = 0.04

    monthly_interest_rate = annual_rate / 12
    monthly_payment = (principal * monthly_interest_rate * (1 + monthly_interest_rate)**months) / \
                  ((1 + monthly_interest_rate)**months - 1)
    total_repayment = monthly_payment * months
    
    print("-"*20 + "Loan Amortization Schedule" + "-" * 20)

    remaining_principal = principal
    # Implement a for loop here

    for month in range(1, months + 1):
        interest_paid = remaining_principal * monthly_interest_rate
        principal_paid = monthly_payment - interest_paid
        remaining_principal -= principal_paid

        print(f"Month: {month}, Amount paid: ${monthly_payment: 0.2f}, Principal: ${principal_paid: 0.2f}, Interest: ${interest_paid:0.2f}, Remaining Principal: ${remaining_principal:0.2f}")
    
    print("-"*20 + "Loan Amortization Schedule" + "-" * 20)
    print(f"The total repayment over {months} months is {total_repayment:0.2f}")
    

    # don't forget to implement code to change user_accepted_loan to True when user selects 'Y'
    proceed = input("Would you like to proceed with the above loan? [Y/N]: ").upper()
    if proceed == 'Y':
        user_accepted_loan = True # this needs to go inside an if
    else:
        print("Restarting application...")
        
print("Thank you for lending with us. Good luck!")