#5.b Understanding inputs to the functions
#Call the function validate_inputs so that it produces the following output. Note you need to call the function five times. Each time you need to pass a different input to the function.

#"Message 1: Both inputs are identical!"
#"Message 2: The first input is greater than the second!"
#"Message 3: The second input is greater than the first!"
#"Message 4: Both inputs are text strings!"
#"Message 5: Inputs are of mixed or special types!"

def validate_inputs(input1, input2):
    
    # Convert inputs to numbers if they are numeric strings
    try:
        num1 = float(input1)
        num2 = float(input2)
        is_numeric = True
    except (ValueError, TypeError):
        is_numeric = False
        num1 = num2 = 0
    
    # Message 1: Both inputs are equal
    if input1 == input2:
        print("Message 1: Both inputs are identical!")
    
    # Message 2: First input is greater (for numeric inputs)
    elif is_numeric and num1 > num2:
        print("Message 2: The first input is greater than the second!")
    
    # Message 3: Second input is greater (for numeric inputs)
    elif is_numeric and num1 < num2:
        print("Message 3: The second input is greater than the first!")
    
    # Message 4: Inputs are strings
    elif type(input1)== str and type(input2) == str:
        print("Message 4: Both inputs are text strings!")
    
    # Message 5: Default case
    else:
        print("Message 5: Inputs are of mixed or special types!")

